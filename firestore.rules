rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userRole() {
      return signedIn() && request.auth.token.role != null
        ? request.auth.token.role
        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isTeacher() {
      return signedIn() && userRole() == "teacher";
    }

    function isStudent() {
      return signedIn() && userRole() == "student";
    }

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }

    function isGroupMember(groupId) {
      return signedIn() && request.auth.uid in groupDoc(groupId).members;
    }

    function isGroupOwner(groupId) {
      return signedIn() && request.auth.uid == groupDoc(groupId).ownerId;
    }

    function isHackathonSelfJoin() {
      return isStudent() &&
        resource.data.type == "hackathon" &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["members"]) &&
        !(request.auth.uid in resource.data.members) &&
        request.auth.uid in request.resource.data.members &&
        request.resource.data.members.size() == resource.data.members.size() + 1 &&
        request.resource.data.members.hasAll(resource.data.members);
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /subjects/{subjectId} {
      allow read: if signedIn();
      allow create: if isTeacher();
      allow update, delete: if isTeacher() && request.auth.uid == resource.data.teacherId;
    }

    match /enrollments/{enrollmentId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update, delete: if signedIn() &&
        (request.auth.uid == resource.data.studentId ||
          request.auth.uid == get(/databases/$(database)/documents/subjects/$(resource.data.subjectId)).data.teacherId);
    }

    match /groups/{groupId} {
      allow read: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() &&
        (isGroupOwner(groupId) ||
          (isTeacher() && resource.data.type == "class") ||
          isHackathonSelfJoin());
    }

    match /tasks/{taskId} {
      allow read: if signedIn() && isGroupMember(resource.data.groupId);
      allow create, update: if signedIn() && isGroupMember(request.resource.data.groupId);
      allow delete: if signedIn() && isGroupOwner(resource.data.groupId);
    }

    match /messages/{messageId} {
      allow read: if signedIn() && isGroupMember(resource.data.groupId);
      allow create: if signedIn() && isGroupMember(request.resource.data.groupId);
      allow update, delete: if signedIn() && request.auth.uid == resource.data.senderId;
    }

    match /progress/{progressId} {
      allow read: if signedIn();
      allow create, update: if signedIn();
    }
  }
}
