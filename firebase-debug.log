[debug] [2026-04-01T06:20:48.015Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/educore-app-2026/rulesets {"name":"projects/educore-app-2026/rulesets/b8f886e4-1134-4d03-85f2-7a859531752d","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function isOwner(userId) {\n      return signedIn() && request.auth.uid == userId;\n    }\n\n    function userRole() {\n      return signedIn() && request.auth.token.role != null\n        ? request.auth.token.role\n        : get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;\n    }\n\n    function isTeacher() {\n      return signedIn() && userRole() == \"teacher\";\n    }\n\n    function isStudent() {\n      return signedIn() && userRole() == \"student\";\n    }\n\n    function groupDoc(groupId) {\n      return get(/databases/$(database)/documents/groups/$(groupId)).data;\n    }\n\n    function isGroupMember(groupId) {\n      return signedIn() && request.auth.uid in groupDoc(groupId).members;\n    }\n\n    function isGroupOwner(groupId) {\n      return signedIn() && request.auth.uid == groupDoc(groupId).ownerId;\n    }\n\n    function isHackathonSelfJoin() {\n      return isStudent() &&\n        resource.data.type == \"hackathon\" &&\n        request.resource.data.diff(resource.data).affectedKeys().hasOnly([\"members\"]) &&\n        !(request.auth.uid in resource.data.members) &&\n        request.auth.uid in request.resource.data.members &&\n        request.resource.data.members.size() == resource.data.members.size() + 1 &&\n        request.resource.data.members.hasAll(resource.data.members);\n    }\n\n    match /users/{userId} {\n      allow read: if signedIn();\n      allow create: if isOwner(userId);\n      allow update: if isOwner(userId);\n    }\n\n    match /subjects/{subjectId} {\n      allow read: if signedIn();\n      allow create: if isTeacher();\n      allow update, delete: if isTeacher() && request.auth.uid == resource.data.teacherId;\n    }\n\n    match /enrollments/{enrollmentId} {\n      allow read: if signedIn();\n      allow create: if signedIn();\n      allow update, delete: if signedIn() &&\n        (request.auth.uid == resource.data.studentId ||\n          request.auth.uid == get(/databases/$(database)/documents/subjects/$(resource.data.subjectId)).data.teacherId);\n    }\n\n    match /groups/{groupId} {\n      allow read: if signedIn();\n      allow create: if signedIn();\n      allow update: if signedIn() &&\n        (isGroupOwner(groupId) ||\n          (isTeacher() && resource.data.type == \"class\") ||\n          isHackathonSelfJoin());\n    }\n\n    match /tasks/{taskId} {\n      allow read: if signedIn() && isGroupMember(resource.data.groupId);\n      allow create, update: if signedIn() && isGroupMember(request.resource.data.groupId);\n      allow delete: if signedIn() && isGroupOwner(resource.data.groupId);\n    }\n\n    match /messages/{messageId} {\n      allow read: if signedIn() && isGroupMember(resource.data.groupId);\n      allow create: if signedIn() && isGroupMember(request.resource.data.groupId);\n      allow update, delete: if signedIn() && request.auth.uid == resource.data.senderId;\n    }\n\n    match /progress/{progressId} {\n      allow read: if signedIn();\n      allow create, update: if signedIn();\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-04-01T06:20:48.475023Z","metadata":{"services":["cloud.firestore"]}}
